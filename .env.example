# Required:
DISCORD_TOKEN=your-bot-token

# Optional — the alert channel can be set live in Discord with /setchannel instead.
# If both are set, /setchannel (stored in the DB) wins. Leave blank to set it from Discord.
ALERT_CHANNEL_ID=
HEALTH_CHANNEL_ID=

# Optional — your Discord server (guild) ID. Set it to make slash-command changes appear
# INSTANTLY in that server instead of waiting up to ~1h for global propagation. Leave blank
# and the bot auto-syncs to every server it's in, so you usually don't need to set this.
DISCORD_GUILD_ID=

DB_PATH=./poe2bot.db
POLL_INTERVAL_MIN=30
POE2SCOUT_UA=poe2bot/0.1 (contact: you@example.com)
DEAD_MAN_URL=
